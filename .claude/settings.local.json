{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm list *)",
      "Bash(npm outdated)",
      "Bash(npm audit)",
      "Bash(npx tsc *)",
      "Bash(npx tsx *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git remote *)",
      "Bash(git status *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr checks *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(dig *)",
      "Bash(firebase hosting:sites:list *)",
      "Bash(firebase hosting:channel:list *)",
      "Bash(firebase projects:list)",
      "Bash(firebase --version)",
      "Bash(firebase help *)",
      "Bash(gcloud iam get-iam-policy *)",
      "Bash(gcloud iam list-*)",
      "Bash(node --version)",
      "Bash(python3 --version)",
      "Bash(xargs ls *)",
      "Bash(xargs basename *)",
      "Bash(curl -s -I *)",
      "Bash(curl -s -o /dev/null *)",
      "Bash(cat)",
      "Bash(gh issue *)",
      "Bash(gh auth *)",
      "Bash(gh label *)",
      "Bash(npm test *)",
      "Bash(sed -n *)",
      "Bash(gh repo view *)",
      "Skill(code-review)",
      "Skill(code-review:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c 'if (.tool_input.command | test(\"gh issue view\")) then {hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"allow\",permissionDecisionReason:\"gh issue view is read-only and pre-approved for /issue\"}} else empty end'"
          }
        ]
      }
    ]
  }
}
